# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── SSH / Claude Code Bridge ──────────────────────────────────
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=your_username
SSH_KEY_PATH=/home/user/.ssh/id_rsa   # leave blank to use SSH_PASSWORD instead
SSH_PASSWORD=                          # leave blank if using SSH_KEY_PATH
SSH_CLAUDE=claude                      # command name on the remote machine

# ── App config (optional overrides) ──────────────────────────
WEATHER_CITY=Toppenstedt
WS_PORT=8765
